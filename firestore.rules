rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- GLOBAL HELPERS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email in ['motrafincc@gmail.com', 'motrafin14@gmail.com'] && request.auth.token.email_verified == true
      );
    }

    function isSuspended() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'suspended';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- COLLECTION RULES ---

    // Users collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'role', 'lastLogin']) &&
               data.uid is string && data.uid.size() <= 128 &&
               data.email is string && data.email.size() <= 200 &&
               data.role in ['admin', 'user', 'suspended'] &&
               data.lastLogin is number &&
               (!data.keys().hasAny(['deviceIds']) || (data.deviceIds is list && data.deviceIds.size() <= 3));
      }

      allow get: if isValidId(userId) && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      
      allow create: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().role == 'user' || 
        (incoming().role == 'admin' && isAdmin())
      );
      
      allow update: if isValidId(userId) && (
        isAdmin() || 
        (isOwner(userId) && 
         isValidUser(incoming()) && 
         incoming().uid == existing().uid &&
         incoming().email == existing().email &&
         (
           (incoming().role == existing().role && incoming().diff(existing()).affectedKeys().hasOnly(['lastLogin', 'displayName', 'photoURL', 'deviceIds'])) ||
           (existing().role == 'user' && incoming().role == 'suspended' && incoming().diff(existing()).affectedKeys().hasOnly(['role', 'deviceIds', 'lastLogin']))
         )
        )
      );
    }

    // Orders collection
    match /orders/{orderId} {
      function isValidOrder(data) {
        return data.keys().hasAll(['email', 'name', 'phone', 'paymentMethod', 'senderAccount', 'transactionId', 'finalPrice', 'productId', 'status', 'createdAt']) &&
               data.email is string && data.email.size() <= 200 &&
               data.name is string && data.name.size() <= 100 &&
               data.phone is string && data.phone.size() <= 30 &&
               data.paymentMethod is string && data.paymentMethod.size() <= 50 &&
               data.senderAccount is string && data.senderAccount.size() <= 50 &&
               data.transactionId is string && data.transactionId.size() <= 100 &&
               data.finalPrice is number &&
               data.productId is string && data.productId.size() <= 128 &&
               data.status in ['pending', 'approved', 'rejected'] &&
               data.createdAt is number;
      }

      allow get: if isValidId(orderId) && (isAdmin() || (isSignedIn() && existing().userId == request.auth.uid));
      allow list: if isAdmin() || (isSignedIn() && !isSuspended() && resource.data.userId == request.auth.uid);
      
      allow create: if !isSuspended() && isValidOrder(incoming()) && incoming().status == 'pending';
      
      allow update: if isValidId(orderId) && (
        isAdmin() || (
          isSignedIn() && 
          !isSuspended() &&
          existing().userId == 'guest' && 
          incoming().userId == request.auth.uid && 
          incoming().diff(existing()).affectedKeys().hasOnly(['userId', 'email'])
        )
      );

      allow delete: if isValidId(orderId) && isAdmin();
    }

    // Products collection
    match /products/{productId} {
      function isValidProduct(data) {
        return data.keys().hasAll(['title', 'price', 'downloadLink', 'isActive']) &&
               data.title is string && data.title.size() <= 200 &&
               data.price is number &&
               data.downloadLink is string && data.downloadLink.size() <= 1000 &&
               data.isActive is bool;
      }

      allow get: if isValidId(productId);
      allow list: if true;
      
      allow create: if isAdmin() && isValidProduct(incoming());
      
      allow update: if isValidId(productId) && (
        isAdmin() || (
          isSignedIn() && 
          !isSuspended() && 
          incoming().diff(existing()).affectedKeys().hasOnly(['downloadsCount'])
        )
      );
    }

    // Coupons collection
    match /coupons/{couponId} {
      function isValidCoupon(data) {
        return data.keys().hasAll(['code', 'discountType', 'discountValue', 'isActive']) &&
               data.code is string && data.code.size() <= 50 &&
               data.discountType in ['percentage', 'fixed'] &&
               data.discountValue is number &&
               data.isActive is bool;
      }

      allow get: if isValidId(couponId);
      allow list: if true; // Publicly listable for validation
      
      allow write: if isAdmin() && isValidCoupon(incoming());
    }

    // Settings collection
    match /settings/landingPage {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
